# prompt-to-asset — provider API keys and pipeline URLs
#
# Copy to `.env` and fill in only the providers you want to enable. The MCP
# server reads these once at startup (packages/mcp-server/src/config.ts).
# Missing keys disable the corresponding provider; the router falls back to
# the next-best option. You can also continue keyless via inline_svg (the
# hosting LLM writes the SVG) or external_prompt_only (paste into any web
# UI, then call asset_ingest_external).

# --- Direct-API providers (api mode) ---

# OpenAI — gpt-image-1 / gpt-image-1.5 (real transparent PNG, best text ≤ 3 words).
OPENAI_API_KEY=

# Google — Imagen 4 / Gemini Flash Image ("Nano Banana"). Photoreal; NOT transparency.
# Either GEMINI_API_KEY or GOOGLE_API_KEY works.
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Ideogram — Ideogram 3 / 3 Turbo (best quoted-text wordmarks; style:"transparent").
IDEOGRAM_API_KEY=

# Recraft — Recraft V3 (the only production model with native SVG output).
RECRAFT_API_KEY=

# Black Forest Labs — Flux Pro / Flux.2 / Flux Schnell / Flux Dev / Kontext.
# Either BFL_API_KEY or TOGETHER_API_KEY works.
BFL_API_KEY=
# TOGETHER_API_KEY=

# Stability AI — SD 1.5, SDXL, SD3 Large, Playground v3 hosted.
STABILITY_API_KEY=

# Leonardo.Ai — Phoenix 1.0 + SDXL presets.
LEONARDO_API_KEY=

# fal.ai aggregator — alternative path for Flux Pro / Flux.2 / SDXL when BFL
# keys are unavailable. Either FAL_API_KEY or FAL_KEY works.
FAL_API_KEY=
# FAL_KEY=

# Cloudflare Workers AI — FREE 10,000 neurons/day (no paid plan required).
# Hosts Flux.2 klein/dev, Flux-1 Schnell, SDXL base + Lightning, DreamShaper,
# Leonardo Phoenix + Lucid Origin. Get both from https://dash.cloudflare.com
# (the account ID is on every dashboard page; tokens at /profile/api-tokens).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Replicate — universal catalog (Flux / SDXL / SD3 / Recraft / Ideogram behind
# one key). Signup comes with a trial credit; beyond that it's paid per-run.
# Get a token at https://replicate.com/account/api-tokens.
REPLICATE_API_TOKEN=

# --- Paste-only providers (external_prompt_only) ---
# These do not expose a public REST API; api mode will throw a clear hint
# pointing you at the web UI. No env var needed.
# - Midjourney (https://www.midjourney.com/app, or Discord /imagine)
# - Adobe Firefly (https://firefly.adobe.com — enterprise-only API)
# - Krea (https://www.krea.ai)

# --- Post-processing pipeline endpoints (all optional) ---

# Background-matte service (BiRefNet / BRIA RMBG-2.0). Falls back to a local
# white-chroma heuristic when unset.
PROMPT_TO_BUNDLE_RMBG_URL=

# Recraft vectorize endpoint (if you have a Recraft /vectorize URL).
PROMPT_TO_BUNDLE_RECRAFT_VECTORIZE_URL=

# Upscaler (DAT2 / Real-ESRGAN / SUPIR / APISR-DAT RGBA).
PROMPT_TO_BUNDLE_UPSCALER_URL=

# VLM-as-judge (Claude Sonnet / GPT-4o vision) for tier-2 validation.
PROMPT_TO_BUNDLE_VLM_URL=

# --- Output + transport overrides (optional) ---

# Default: ./assets under cwd.
# PROMPT_TO_BUNDLE_OUTPUT_DIR=./assets
# Default: ./.asset-cache.
# PROMPT_TO_BUNDLE_CACHE_DIR=./.asset-cache
# stdio (default) or http.
# PROMPT_TO_BUNDLE_TRANSPORT=stdio
# PROMPT_TO_BUNDLE_HTTP_PORT=3333
# Dry-run (1 = return fixture pixels instead of hitting providers; useful for tests).
# PROMPT_TO_BUNDLE_DRY_RUN=1
