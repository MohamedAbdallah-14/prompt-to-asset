{
  "name": "prompt-to-asset",
  "version": "0.1.0",
  "description": "prompt-to-asset MCP server — generate production-grade software assets (logos, app icons, favicons, OG images, illustrations, vectors, transparent marks) via routed model providers and a deterministic post-processing pipeline.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "p2a": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/yourorg/prompt-to-asset.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/yourorg/prompt-to-asset#readme",
  "bugs": {
    "url": "https://github.com/yourorg/prompt-to-asset/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "cursor",
    "prompt-engineering",
    "image-generation",
    "logo",
    "app-icon",
    "favicon",
    "og-image"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "smoke": "node dist/smoke.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "sharp": "^0.33.5",
    "tesseract.js": "^5.1.1",
    "png-to-ico": "^2.1.8",
    "satori": "^0.10.14",
    "@resvg/resvg-js": "^2.6.2",
    "svgo": "^3.3.2",
    "@fontsource/inter": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
