{
  "name": "prompt-to-asset-monorepo",
  "version": "0.3.1",
  "private": true,
  "description": "prompt-to-asset for dev assets — reliably generate production-grade software assets (logos, app icons, favicons, OG images, vectors, transparent marks) from simple briefs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MohamedAbdallah-14/prompt-to-asset.git"
  },
  "homepage": "https://github.com/MohamedAbdallah-14/prompt-to-asset#readme",
  "bugs": {
    "url": "https://github.com/MohamedAbdallah-14/prompt-to-asset/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude-code",
    "cursor",
    "prompt-engineering",
    "image-generation",
    "logo",
    "app-icon",
    "favicon",
    "og-image",
    "svg",
    "transparent-png",
    "ideogram",
    "recraft",
    "flux",
    "gpt-image-1"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run -w prompt-to-asset build",
    "dev": "npm run -w prompt-to-asset dev",
    "typecheck": "npm run -w prompt-to-asset typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sync": "bash scripts/sync-mirrors.sh",
    "verify": "bash scripts/verify-repo.sh",
    "smoke": "npm run -w prompt-to-asset smoke",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/utils": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vitest": "^4.1.4"
  }
}
