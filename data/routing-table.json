{
  "$schema": "./schemas/routing-table.schema.json",
  "version": "1.1.0",
  "updated": "2026-04-20",
  "source": "docs/research/SYNTHESIS.md § Model Capability Matrix and § Highest-Confidence Recommendations",
  "rules": [
    {
      "id": "transparent-mark",
      "when": { "asset_type": "transparent_mark" },
      "primary": { "model": "gpt-image-1", "params": { "background": "transparent", "output_format": "png" } },
      "fallback": [
        { "model": "ideogram-3-turbo", "params": { "style": "transparent" } },
        { "model": "recraft-v3", "params": { "output_format": "svg" }, "postprocess": ["rasterize_svg"] }
      ],
      "never": ["imagen-3", "imagen-4", "gemini-3-flash-image", "sd-1.5", "dall-e-3"],
      "postprocess": ["validate_alpha", "reject_checkerboard"],
      "research_sources": [
        "docs/research/04-gemini-imagen-prompting/4c-transparent-background-checkerboard.md",
        "docs/research/05-openai-dalle-gpt-image/5b-gpt-image-1-api.md",
        "docs/research/13-transparent-backgrounds/",
        "docs/research/07-midjourney-ideogram-recraft/7b-ideogram-text-rendering-for-logos.md"
      ]
    },
    {
      "id": "logo-text-free-vector",
      "when": { "asset_type": "logo", "text_length": 0, "vector_required": true },
      "primary": { "model": "recraft-v3", "params": { "output_format": "svg" } },
      "fallback": [
        { "model": "gpt-image-1", "params": { "background": "transparent" }, "postprocess": ["birefnet_matte", "kmeans_quantize", "vtracer", "svgo"] }
      ],
      "never": ["imagen-3", "imagen-4", "sd-1.5"],
      "postprocess": ["svgo_conservative", "validate_svg_path_count"],
      "research_sources": [
        "docs/research/07-midjourney-ideogram-recraft/7c-recraft-v3-native-svg.md",
        "docs/research/08-logo-generation/8e-svg-vector-logo-pipeline.md",
        "docs/research/12-vector-svg-generation/"
      ]
    },
    {
      "id": "logo-with-text-1-3-words",
      "when": { "asset_type": "logo", "text_length": "1..3", "vector_required": false },
      "primary": { "model": "ideogram-3-turbo" },
      "fallback": [
        { "model": "gpt-image-1", "params": { "background": "transparent" } },
        { "model": "recraft-v3" }
      ],
      "never": ["imagen-3", "sd-1.5", "flux-schnell"],
      "postprocess": ["birefnet_matte", "validate_alpha", "ocr_wordmark_check"],
      "research_sources": [
        "docs/research/07-midjourney-ideogram-recraft/7b-ideogram-text-rendering-for-logos.md",
        "docs/research/05-openai-dalle-gpt-image/5c-logo-icon-generation.md",
        "docs/research/08-logo-generation/8c-text-rendering-in-logos.md"
      ]
    },
    {
      "id": "logo-with-text-many-words",
      "when": { "asset_type": "logo", "text_length": ">3" },
      "primary": { "strategy": "composite", "mark_model": "recraft-v3", "typography": "svg_composite" },
      "fallback": [],
      "never": ["any_diffusion_for_the_text"],
      "postprocess": ["validate_composite"],
      "research_sources": [
        "docs/research/08-logo-generation/8c-text-rendering-in-logos.md",
        "docs/research/23-combinations/",
        "docs/research/SYNTHESIS.md"
      ]
    },
    {
      "id": "app-icon-mark",
      "when": { "asset_type": "app_icon" },
      "primary": { "model": "recraft-v3" },
      "fallback": [
        { "model": "ideogram-3-turbo" },
        { "model": "gpt-image-1", "params": { "background": "transparent" } }
      ],
      "never": ["imagen-3", "imagen-4"],
      "postprocess": ["birefnet_matte", "center_frame_check", "export_app_icon_set"],
      "research_sources": [
        "docs/research/09-app-icon-generation/9a-ios-app-icon-hig-specs.md",
        "docs/research/09-app-icon-generation/9b-android-adaptive-themed.md",
        "docs/research/09-app-icon-generation/9c-pwa-manifest-maskable.md"
      ]
    },
    {
      "id": "favicon",
      "when": { "asset_type": "favicon" },
      "primary": { "strategy": "svg_first", "model": "recraft-v3", "params": { "output_format": "svg" } },
      "fallback": [
        { "strategy": "llm_author_svg", "model": "claude-sonnet" },
        { "model": "gpt-image-1", "postprocess": ["birefnet_matte", "kmeans_quantize", "potrace", "svgo"] }
      ],
      "never": ["imagen-3"],
      "postprocess": ["wcag_16px_check", "export_favicon_bundle"],
      "research_sources": [
        "docs/research/11-favicon-web-assets/"
      ]
    },
    {
      "id": "og-image",
      "when": { "asset_type": "og_image" },
      "primary": { "strategy": "satori_template" },
      "fallback": [
        { "strategy": "satori_with_diffusion_hero", "hero_model": "flux-pro" }
      ],
      "never": [],
      "postprocess": ["validate_og_dimensions", "wcag_text_contrast"],
      "research_sources": [
        "docs/research/11-favicon-web-assets/",
        "docs/research/18-asset-pipeline-tools/"
      ]
    },
    {
      "id": "illustration-branded",
      "when": { "asset_type": "illustration", "brand_bundle_present": true },
      "primary": { "model": "flux-2", "params": { "reference_images": "brand.style_refs" } },
      "fallback": [
        { "model": "flux-pro", "params": { "lora": "brand.lora" } },
        { "model": "recraft-v3", "params": { "style_id": "brand.style_id" } },
        { "model": "sdxl", "params": { "lora": "brand.lora" } }
      ],
      "never": ["imagen-3"],
      "postprocess": ["palette_delta_e_check", "set_coherence_check"],
      "research_sources": [
        "docs/research/15-style-consistency-brand/",
        "docs/research/06-stable-diffusion-flux/6b-flux-family-prompting.md",
        "docs/research/07-midjourney-ideogram-recraft/7c-recraft-v3-native-svg.md"
      ]
    },
    {
      "id": "illustration-no-brand",
      "when": { "asset_type": "illustration", "brand_bundle_present": false },
      "primary": { "model": "flux-pro" },
      "fallback": [
        { "model": "ideogram-3-turbo" },
        { "model": "gpt-image-1" }
      ],
      "never": [],
      "postprocess": [],
      "research_sources": [
        "docs/research/10-ui-illustrations-graphics/",
        "docs/research/06-stable-diffusion-flux/6b-flux-family-prompting.md"
      ]
    },
    {
      "id": "hero-photoreal",
      "when": { "asset_type": "hero", "style": "photoreal" },
      "primary": { "model": "flux-pro" },
      "fallback": [
        { "model": "gpt-image-1" },
        { "model": "imagen-4" }
      ],
      "never": ["dall-e-3"],
      "postprocess": ["upscale_if_under_2k", "validate_composition"],
      "research_sources": [
        "docs/research/06-stable-diffusion-flux/6b-flux-family-prompting.md",
        "docs/research/04-gemini-imagen-prompting/",
        "docs/research/17-upscaling-refinement/"
      ]
    },
    {
      "id": "icon-pack",
      "when": { "asset_type": "icon_pack" },
      "primary": { "strategy": "llm_author_svg", "model": "claude-sonnet", "constraints": { "viewbox": "0 0 24 24", "stroke": 2, "fill": "currentColor", "max_paths": 12 } },
      "fallback": [
        { "model": "recraft-v3", "params": { "output_format": "svg" } }
      ],
      "never": [],
      "postprocess": ["svgo_conservative", "validate_svg_path_count"],
      "research_sources": [
        "docs/research/10-ui-illustrations-graphics/10c-spot-illustrations-and-icon-packs.md",
        "docs/research/12-vector-svg-generation/"
      ]
    },
    {
      "id": "splash-screen",
      "when": { "asset_type": "splash_screen" },
      "primary": { "strategy": "composite_mark_on_background", "mark_model": "recraft-v3" },
      "fallback": [
        { "model": "gpt-image-1", "params": { "background": "transparent" }, "postprocess": ["birefnet_matte"] },
        { "model": "ideogram-3-turbo", "params": { "style": "transparent" } }
      ],
      "never": ["imagen-3", "imagen-4"],
      "postprocess": ["center_frame_check", "export_splash_screen_bundle"],
      "research_sources": [
        "docs/research/09-app-icon-generation/",
        "docs/research/18-asset-pipeline-tools/"
      ]
    },
    {
      "id": "sticker",
      "when": { "asset_type": "sticker" },
      "primary": { "model": "gpt-image-1", "params": { "background": "transparent" } },
      "fallback": [
        { "model": "ideogram-3-turbo", "params": { "style": "transparent" } },
        { "model": "sdxl", "params": { "layerdiffuse": true } }
      ],
      "never": ["imagen-3"],
      "postprocess": ["validate_alpha", "tight_bbox"],
      "research_sources": [
        "docs/research/13-transparent-backgrounds/",
        "docs/research/05-openai-dalle-gpt-image/5b-gpt-image-1-api.md"
      ]
    }
  ]
}
